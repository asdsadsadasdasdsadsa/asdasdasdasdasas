local function Notify(text)
    local Notif = Instance.new("TextLabel")
    Notif.Size = UDim2.new(0, 200, 0, 40); Notif.Position = UDim2.new(0.5, -100, 0.8, 0)
    Notif.BackgroundColor3 = Color3.fromRGB(30, 30, 35); Notif.TextColor3 = Color3.fromRGB(255, 255, 255)
    Notif.Text = text; Notif.Font = Enum.Font.GothamBold; Notif.TextSize = 14; Notif.Parent = ScreenGui
    Instance.new("UICorner", Notif).CornerRadius = UDim.new(0, 8)
    table.insert(AccentObjects.Texts, Notif); Notif.TextColor3 = getgenv().EvadeData.AccentColor
    
    TweenService:Create(Notif, TweenInfo.new(0.3), {Position = UDim2.new(0.5, -100, 0.75, 0)}):Play()
    task.delay(2, function()
        local hide = TweenService:Create(Notif, TweenInfo.new(0.3), {BackgroundTransparency = 1, TextTransparency = 1})
        hide:Play(); hide.Completed:Wait(); Notif:Destroy()
    end)
end

