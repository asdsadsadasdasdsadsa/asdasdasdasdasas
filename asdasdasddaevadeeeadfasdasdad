-- // UPDATE THEME \\ --
local function UpdateTheme(color)
    getgenv().EvadeData.AccentColor = color
    for _, obj in pairs(AccentObjects.Backgrounds) do if obj and obj.Parent then TweenService:Create(obj, TweenInfo.new(0.3), {BackgroundColor3 = color}):Play() end end
    for _, obj in pairs(AccentObjects.Texts) do if obj and obj.Parent then TweenService:Create(obj, TweenInfo.new(0.3), {TextColor3 = color}):Play() end end
    for _, obj in pairs(AccentObjects.Strokes) do if obj and obj.Parent then TweenService:Create(obj, TweenInfo.new(0.3), {Color = color}):Play() end end
end

