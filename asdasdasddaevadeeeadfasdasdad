-- // ADVANCED FLY & SPEED SYSTEM (DRIFT FIX) \\ --
RunService.Heartbeat:Connect(function()
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChild("Humanoid")
    local root = char and char:FindFirstChild("HumanoidRootPart")
    
    if hum and root then
        -- FLY LOGIC
        if getgenv().EvadeData.FlyEnabled then
            hum.PlatformStand = true
            
            local bv = root:FindFirstChild("ZypheraFly")
            if not bv then
                bv = Instance.new("BodyVelocity")
                bv.Name = "ZypheraFly"; bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge); bv.Velocity = Vector3.new(0, 0, 0); bv.Parent = root
            end
            
            local moveVec = Vector3.new(0,0,0)
            if ControlModule then
                moveVec = ControlModule:GetMoveVector()
            else
                local x, z = 0, 0
                if UserInputService:IsKeyDown(Enum.KeyCode.W) then z = -1 end
                if UserInputService:IsKeyDown(Enum.KeyCode.S) then z = 1 end
                if UserInputService:IsKeyDown(Enum.KeyCode.A) then x = -1 end
                if UserInputService:IsKeyDown(Enum.KeyCode.D) then x = 1 end
                moveVec = Vector3.new(x, 0, z)
            end
            
            local flyDir = Camera.CFrame:VectorToWorldSpace(moveVec)
            
            if not IsMobile then
                local yMove = 0
                if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then yMove = 1 end
                if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then yMove = -1 end
                flyDir = flyDir + Vector3.new(0, yMove, 0)
            end
            
            if flyDir.Magnitude > 0 then
                bv.Velocity = flyDir.Unit * getgenv().EvadeData.FlySpeed
            else
                bv.Velocity = Vector3.new(0, 0, 0); root.AssemblyLinearVelocity = Vector3.new(0, 0, 0); root.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
            end
            
        -- SPEED LOGIC
        else
            local bv = root:FindFirstChild("ZypheraFly")
            if bv then bv:Destroy() end
            
            if hum.PlatformStand then hum.PlatformStand = false end
            
            if getgenv().EvadeData.SpeedEnabled and hum.MoveDirection.Magnitude > 0 then
                local vel = hum.MoveDirection * getgenv().EvadeData.SpeedValue
                root.Velocity = Vector3.new(vel.X, root.Velocity.Y, vel.Z)
            end
        end
    end
end)

-- // ADVANCED ESP DRAWING \\ --
local ESPObjects, BotESPObjects = {}, {}

local function ClearESP(ObjTable, Target)
    if ObjTable[Target] then for _, obj in pairs(ObjTable[Target]) do pcall(function() obj:Remove() end) end; ObjTable[Target] = nil end
end

local function CreateESPData(TargetTable, Target)
    ClearESP(TargetTable, Target)
    TargetTable[Target] = { Box = Drawing.new("Square"), Tracer = Drawing.new("Line"), Name = Drawing.new("Text"), Distance = Drawing.new("Text"), HealthBg = Drawing.new("Square"), HealthBar = Drawing.new("Square") }
    local E = TargetTable[Target]
    E.Box.Thickness = 1.5; E.Box.Filled = false; E.Tracer.Thickness = 1.5; E.Tracer.Transparency = 1; E.Name.Size = 16; E.Name.Center = true; E.Name.Outline = true; E.Distance.Size = 14; E.Distance.Center = true; E.Distance.Outline = true
    E.HealthBg.Filled = true; E.HealthBg.Color = Color3.fromRGB(0, 0, 0); E.HealthBg.Transparency = 0.5; E.HealthBar.Filled = true
    for _, v in pairs(E) do v.Visible = false end
end

-- // MAIN ESP RENDER LOOP \\ --
RunService.RenderStepped:Connect(function()
    local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    local anyESP = getgenv().EvadeData.ESPBox or getgenv().EvadeData.ESPNames or getgenv().EvadeData.ESPDistance or getgenv().EvadeData.ESPHealth or getgenv().EvadeData.ESPTracer
    
    -- PLAYER ESP
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            if not ESPObjects[p] then CreateESPData(ESPObjects, p) end
            local E, Char = ESPObjects[p], p.Character
            local Root, Hum = Char and Char:FindFirstChild("HumanoidRootPart"), Char and Char:FindFirstChild("Humanoid")
            
            if Char and Root and Hum and Hum.Health > 0 and anyESP then
                local ScreenPos, OnScreen = Camera:WorldToViewportPoint(Root.Position)
                if OnScreen then
                    local isDowned = Char:FindFirstChildWhichIsA("ProximityPrompt", true) ~= nil
                    local EspColor = isDowned and Color3.fromRGB(255, 60, 60) or Color3.fromRGB(60, 255, 60)
                    local Distance = myRoot and math.floor((myRoot.Position - Root.Position).Magnitude) or 0
                    local Scale = 400 / ScreenPos.Z; local Height = 5 * Scale; local Width = 3 * Scale
                    local BoxX, BoxY = ScreenPos.X - Width / 2, ScreenPos.Y - Height / 2
                    
                    if getgenv().EvadeData.ESPBox then E.Box.Visible = true; E.Box.Size = Vector2.new(Width, Height); E.Box.Position = Vector2.new(BoxX, BoxY); E.Box.Color = EspColor else E.Box.Visible = false end
                    if getgenv().EvadeData.ESPTracer then E.Tracer.Visible = true; E.Tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y); E.Tracer.To = Vector2.new(ScreenPos.X, ScreenPos.Y + Height/2); E.Tracer.Color = EspColor else E.Tracer.Visible = false end
                    if getgenv().EvadeData.ESPNames then E.Name.Visible = true; E.Name.Text = p.Name; E.Name.Position = Vector2.new(ScreenPos.X, BoxY - 20); E.Name.Color = EspColor else E.Name.Visible = false end
                    if getgenv().EvadeData.ESPDistance then E.Distance.Visible = true; E.Distance.Text = tostring(Distance) .. " Studs"; E.Distance.Position = Vector2.new(ScreenPos.X, BoxY + Height + 5); E.Distance.Color = Color3.fromRGB(255, 255, 255) else E.Distance.Visible = false end
                    
                    if getgenv().EvadeData.ESPHealth then
                        local hpPercent = Hum.Health / Hum.MaxHealth; local barH = Height; local barW = 4; local barX = BoxX - 8
                        E.HealthBg.Visible = true; E.HealthBg.Size = Vector2.new(barW, barH); E.HealthBg.Position = Vector2.new(barX, BoxY)
                        E.HealthBar.Visible = true; E.HealthBar.Size = Vector2.new(barW, barH * hpPercent); E.HealthBar.Position = Vector2.new(barX, BoxY + barH * (1 - hpPercent)); E.HealthBar.Color = Color3.fromRGB(255 * (1 - hpPercent), 255 * hpPercent, 0)
                    else E.HealthBg.Visible = false; E.HealthBar.Visible = false end
                else for _, v in pairs(E) do v.Visible = false end end
            else for _, v in pairs(E) do v.Visible = false end end
        end
    end
    
    -- NEXTBOT ESP
    if getgenv().EvadeData.BotESP then
        local activeBots = {}
        local searchFolders = {workspace}
        local gameFolder = workspace:FindFirstChild("Game")
        if gameFolder then table.insert(searchFolders, gameFolder); local playersFolder = gameFolder:FindFirstChild("Players"); if playersFolder then table.insert(searchFolders, playersFolder) end end
        
        for _, folder in ipairs(searchFolders) do
            for _, obj in pairs(folder:GetChildren()) do
                if obj:IsA("Model") and obj:FindFirstChild("HumanoidRootPart") and not Players:GetPlayerFromCharacter(obj) then activeBots[obj] = true end
            end
        end
        
        for bot, _ in pairs(activeBots) do
            if not BotESPObjects[bot] then CreateESPData(BotESPObjects, bot) end
            local E, Root = BotESPObjects[bot], bot:FindFirstChild("HumanoidRootPart")
            if Root then
                local ScreenPos, OnScreen = Camera:WorldToViewportPoint(Root.Position)
                if OnScreen then
                    local Distance = myRoot and math.floor((myRoot.Position - Root.Position).Magnitude) or 0
                    local Scale = 400 / ScreenPos.Z; local Height = 6 * Scale; local Width = 3.5 * Scale
                    local BoxX, BoxY = ScreenPos.X - Width / 2, ScreenPos.Y - Height / 2
                    
                    if getgenv().EvadeData.ESPBox then E.Box.Visible = true; E.Box.Size = Vector2.new(Width, Height); E.Box.Position = Vector2.new(BoxX, BoxY); E.Box.Color = Color3.fromRGB(255, 50, 50) else E.Box.Visible = false end
                    E.Tracer.Visible = true; E.Tracer.From = Vector2.new(Camera.ViewportSize.X / 2, 0); E.Tracer.To = Vector2.new(ScreenPos.X, ScreenPos.Y - Height/2); E.Tracer.Color = Color3.fromRGB(255, 50, 50)
                    E.Name.Visible = true; E.Name.Text = "[KATİL] " .. bot.Name; E.Name.Position = Vector2.new(ScreenPos.X, BoxY - 20); E.Name.Color = Color3.fromRGB(255, 50, 50)
                    E.Distance.Visible = true; E.Distance.Text = tostring(Distance) .. " Studs"; E.Distance.Position = Vector2.new(ScreenPos.X, BoxY + Height + 5); E.Distance.Color = Color3.fromRGB(255, 150, 150)
                else for _, v in pairs(E) do v.Visible = false end end
            else for _, v in pairs(E) do v.Visible = false end end
        end
        for bot, E in pairs(BotESPObjects) do if not activeBots[bot] then ClearESP(BotESPObjects, bot) end end
    else
        for bot, _ in pairs(BotESPObjects) do ClearESP(BotESPObjects, bot) end
    end
end)

