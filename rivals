local FlyVelo = nil

local function ToggleFly(state)
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    
    if state then
        if FlyVelo then FlyVelo:Destroy() end
        FlyVelo = Instance.new("BodyVelocity")
        -- Sadece Velocity uyguluyoruz, PlatformStand = true yapmıyoruz! (Donmayı çözer)
        FlyVelo.MaxForce = Vector3.new(100000, 100000, 100000)
        FlyVelo.Velocity = Vector3.zero
        FlyVelo.Parent = char.HumanoidRootPart
    else
        if FlyVelo then FlyVelo:Destroy(); FlyVelo = nil end
    end
end

LocalPlayer.CharacterAdded:Connect(function()
    if Settings.FlyEnabled then task.wait(0.5); ToggleFly(true) end
end)

