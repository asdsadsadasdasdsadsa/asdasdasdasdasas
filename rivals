RunService.Heartbeat:Connect(function()
    local char = LocalPlayer.Character
    if char and char:FindFirstChild("Humanoid") and char:FindFirstChild("HumanoidRootPart") then
        local hum = char.Humanoid
        local hrp = char.HumanoidRootPart
        
        -- YENİ SPEED MANTIĞI: CFrame Işınlaması Yerine Doğrudan Fiziksel Hız Uygulaması (Velocity)
        if Settings.SpeedEnabled and hum.MoveDirection.Magnitude > 0 then
            hrp.Velocity = Vector3.new(hum.MoveDirection.X * Settings.SpeedValue, hrp.Velocity.Y, hum.MoveDirection.Z * Settings.SpeedValue)
        end
        
        -- YENİ FLY MANTIĞI: PlatformStand Olmadan, Kameraya Göre Hız
        if Settings.FlyEnabled and FlyVelo then
            local moveDir = hum.MoveDirection
            if moveDir.Magnitude > 0 then
                local cam = workspace.CurrentCamera
                local flatLook = Vector3.new(cam.CFrame.LookVector.X, 0, cam.CFrame.LookVector.Z).Unit
                local flatRight = Vector3.new(cam.CFrame.RightVector.X, 0, cam.CFrame.RightVector.Z).Unit
                
                local dotF = flatLook:Dot(moveDir)
                local dotR = flatRight:Dot(moveDir)
                
                -- Karakteri, joystiğe göre kameranın baktığı yöne iter!
                local flyDir = (cam.CFrame.LookVector * dotF) + (cam.CFrame.RightVector * dotR)
                FlyVelo.Velocity = flyDir.Unit * Settings.FlySpeed
            else
                FlyVelo.Velocity = Vector3.zero
            end
        end
    end
end)

