local function RemoveESP(player)
    if ESPObjects[player] then
        for _, obj in pairs(ESPObjects[player]) do obj:Destroy() end
        ESPObjects[player] = nil
    end
end

Players.PlayerAdded:Connect(CreateESP)
Players.PlayerRemoving:Connect(RemoveESP)
for _, p in pairs(Players:GetPlayers()) do
    if p ~= LocalPlayer then CreateESP(p) end
end

local function HideESP(esp)
    esp.Box.Visible = false
    esp.HealthBg.Visible = false
    esp.Name.Visible = false
    esp.Dist.Visible = false
    esp.Tracer.Visible = false
end

local function UpdateESP()
    for player, esp in pairs(ESPObjects) do
        local char = player.Character
        local isAlive = char and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0 and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Head")
        
        -- Master Switch kalktı. Eğer herhangi biri açıksa oyuncuyu taramaya başla
        if isAlive and (Settings.ESPBox or Settings.ESPHealth or Settings.ESPName or Settings.ESPDist or Settings.ESPTracer) then
            local distance = math.floor((Camera.CFrame.Position - char.HumanoidRootPart.Position).Magnitude)
            
            -- LOBİ FİX: Adam MaxDistance'dan daha uzaksa ESP'yi gizle (Lobidekileri yoksay)
            if distance <= Settings.MaxDistance then
                local rootPos, onScreen = Camera:WorldToViewportPoint(char.HumanoidRootPart.Position)
                
                if onScreen then
                    local headPos = Camera:WorldToViewportPoint(char.Head.Position + Vector3.new(0, 0.5, 0))
                    local legPos = Camera:WorldToViewportPoint(char.HumanoidRootPart.Position - Vector3.new(0, 3, 0))
                    
                    local height = math.abs(headPos.Y - legPos.Y)
                    local width = height * 0.6
                    local healthPerc = char.Humanoid.Health / char.Humanoid.MaxHealth
                    
                    if Settings.ESPBox then
                        esp.Box.Size = UDim2.new(0, width, 0, height)
                        esp.Box.Position = UDim2.new(0, rootPos.X - width/2, 0, headPos.Y)
                        esp.Box.Visible = true
                    else esp.Box.Visible = false end
                    
                    if Settings.ESPHealth then
                        esp.HealthBg.Size = UDim2.new(0, 3, 0, height)
                        esp.HealthBg.Position = UDim2.new(0, rootPos.X - width/2 - 6, 0, headPos.Y)
                        esp.HealthBar.Size = UDim2.new(1, 0, healthPerc, 0)
                        esp.HealthBar.Position = UDim2.new(0, 0, 1 - healthPerc, 0)
                        esp.HealthBar.BackgroundColor3 = Color3.fromHSV(healthPerc * 0.3, 1, 1)
                        esp.HealthBg.Visible = true
                    else esp.HealthBg.Visible = false end
                    
                    if Settings.ESPName then
                        esp.Name.Text = player.Name
                        esp.Name.Position = UDim2.new(0, rootPos.X, 0, headPos.Y - 15)
                        esp.Name.Visible = true
                    else esp.Name.Visible = false end
                    
                    if Settings.ESPDist then
                        esp.Dist.Text = tostring(distance) .. "m"
                        esp.Dist.Position = UDim2.new(0, rootPos.X, 0, headPos.Y + height + 5)
                        esp.Dist.Visible = true
                    else esp.Dist.Visible = false end
                    
                    if Settings.ESPTracer then
                        local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                        local targetPos = Vector2.new(rootPos.X, rootPos.Y)
                        local tracerDist = (targetPos - screenCenter).Magnitude
                        esp.Tracer.Size = UDim2.new(0, tracerDist, 0, 1.5)
                        esp.Tracer.Position = UDim2.new(0, (screenCenter.X + targetPos.X) / 2, 0, (screenCenter.Y + targetPos.Y) / 2)
                        esp.Tracer.Rotation = math.deg(math.atan2(targetPos.Y - screenCenter.Y, targetPos.X - screenCenter.X))
                        esp.Tracer.Visible = true
                    else esp.Tracer.Visible = false end
                else
                    HideESP(esp)
                end
            else
                HideESP(esp) -- Mesafe dışındaysa gizle
            end
        else
            HideESP(esp) -- Ölüyse veya tüm ESP özellikleri kapalıysa gizle
        end
    end
end

