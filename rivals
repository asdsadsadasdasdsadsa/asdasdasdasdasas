local function doSmoothTeleport(targetPos)
    pcall(function()
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local root = LocalPlayer.Character.HumanoidRootPart
            local tween = TweenService:Create(root, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {CFrame = CFrame.new(targetPos)})
            tween:Play()
        end
    end)
end

_G.executeTeleportMode = function()
    pcall(function()
        local mode = Settings.SelectedTeleportMode
        if mode == "Mouse" then
            if LocalPlayer.Character then
                local targetPos
                if isMobile then
                    local ray = Ray.new(Camera.CFrame.Position, Camera.CFrame.LookVector * 500)
                    local hit, pos = workspace:FindPartOnRayWithIgnoreList(ray, {LocalPlayer.Character})
                    targetPos = pos
                else
                    local mousePos = Mouse.Hit.p
                    local ray = Ray.new(mousePos + Vector3.new(0, 10, 0), Vector3.new(0, -20, 0))
                    local hit, pos = workspace:FindPartOnRayWithIgnoreList(ray, {LocalPlayer.Character})
                    targetPos = pos or mousePos
                end
                if targetPos then doSmoothTeleport(targetPos + Vector3.new(0, 3, 0)) end
            end
        elseif mode == "Player" then
            local nearest = _G.getNearestPlayer()
            if nearest and nearest.Character and nearest.Character:FindFirstChild("HumanoidRootPart") then
                doSmoothTeleport(nearest.Character.HumanoidRootPart.Position + Vector3.new(0, 3, 3))
            end
        end
    end)
end

