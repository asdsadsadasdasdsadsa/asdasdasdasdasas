        local Fill = Instance.new("Frame") Fill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0) Fill.BackgroundColor3 = Settings.ThemeColor Fill.Parent = SliderBg
        local FillCorner = Instance.new("UICorner") FillCorner.CornerRadius = UDim.new(1, 0) FillCorner.Parent = Fill
        table.insert(ThemedElements.Bgs, Fill)

        local Knob = Instance.new("Frame") Knob.Size = UDim2.new(0, 14, 0, 14) Knob.Position = UDim2.new(1, -7, 0.5, -7) Knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255) Knob.Parent = Fill
