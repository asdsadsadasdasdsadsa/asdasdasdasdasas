local T = {}
local ThemeUI = { Bgs = {}, Strokes = {}, Texts = {} }
local MobileHUDTexts = {}
local InfoLabels = {}

local function applyTheme()
    for _, obj in pairs(ThemeUI.Bgs) do if obj then pcall(function() obj.BackgroundColor3 = Settings.ThemeColor end) end end
    for _, obj in pairs(ThemeUI.Strokes) do if obj then pcall(function() obj.Color = Settings.ThemeColor end) end end
    for _, obj in pairs(ThemeUI.Texts) do if obj then pcall(function() obj.TextColor3 = Settings.ThemeColor end) end end
end

local function addThemeObj(obj, type)
    table.insert(ThemeUI[type], obj)
    pcall(function()
        if type == "Bgs" then obj.BackgroundColor3 = Settings.ThemeColor
        elseif type == "Strokes" then obj.Color = Settings.ThemeColor
        elseif type == "Texts" then obj.TextColor3 = Settings.ThemeColor end
    end)
end

function UpdateLanguage() 
    T = Translations[Settings.Language] 
    if MobileHUDTexts.Apply then MobileHUDTexts.Apply.Text = T.ApplyTeleport end
    if MobileHUDTexts.Save then MobileHUDTexts.Save.Text = T.SavePos end
    if MobileHUDTexts.Load then MobileHUDTexts.Load.Text = T.LoadPos end
    if MobileHUDTexts.Delete then MobileHUDTexts.Delete.Text = T.DeletePos end
    if InfoLabels.MobileAimbot then InfoLabels.MobileAimbot.Text = T.MobileAimbotInfo end
end
UpdateLanguage()

