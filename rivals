-- UÇUŞ (FLY) SİSTEMİ
function enableFly()
    pcall(function()
        if not LocalPlayer.Character then return end
        local humanoid = LocalPlayer.Character:FindFirstChild("Humanoid")
        local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if humanoid and root then
            humanoid.PlatformStand = true
            if flyBodyVelocity then flyBodyVelocity:Destroy() end
            if flyBodyGyro then flyBodyGyro:Destroy() end
            
            flyBodyVelocity = Instance.new("BodyVelocity", root)
            flyBodyVelocity.MaxForce = Vector3.new(1, 1, 1) * math.huge
            flyBodyVelocity.Velocity = Vector3.new(0, 0, 0)
            
            flyBodyGyro = Instance.new("BodyGyro", root)
            flyBodyGyro.MaxTorque = Vector3.new(1, 1, 1) * math.huge
            flyBodyGyro.CFrame = root.CFrame
            
            if flyConnection then flyConnection:Disconnect() end
            
            flyConnection = RunService.RenderStepped:Connect(function()
                pcall(function()
                    if Settings.FlyEnabled and flyBodyVelocity and LocalPlayer.Character then
                        local md = Vector3.new(0, 0, 0)
                        if isMobile then
                            local moveDir = humanoid.MoveDirection
                            if moveDir.Magnitude > 0 then
                                md = Vector3.new(moveDir.X, Camera.CFrame.LookVector.Y * moveDir.Magnitude, moveDir.Z)
                            end
                        else
                            if UserInputService:IsKeyDown(Enum.KeyCode.W) then md = md + Camera.CFrame.LookVector end
                            if UserInputService:IsKeyDown(Enum.KeyCode.S) then md = md - Camera.CFrame.LookVector end
                            if UserInputService:IsKeyDown(Enum.KeyCode.A) then md = md - Camera.CFrame.RightVector end
                            if UserInputService:IsKeyDown(Enum.KeyCode.D) then md = md + Camera.CFrame.RightVector end
                            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then md = md + Vector3.new(0, 1, 0) end
                            if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then md = md + Vector3.new(0, -1, 0) end
                        end
                        flyBodyVelocity.Velocity = (md.Magnitude > 0) and md.Unit * Settings.FlySpeed or Vector3.new(0,0,0)
                        if flyBodyGyro then flyBodyGyro.CFrame = Camera.CFrame end
                    end
                end)
            end)
        end
    end)
end

function disableFly()
    pcall(function()
        if flyConnection then flyConnection:Disconnect() flyConnection = nil end
        if flyBodyVelocity then flyBodyVelocity:Destroy() flyBodyVelocity = nil end
        if flyBodyGyro then flyBodyGyro:Destroy() flyBodyGyro = nil end
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then 
            LocalPlayer.Character.Humanoid.PlatformStand = false 
        end
    end)
end

function getClosestTarget()
    local closest, closestDist = nil, Settings.FOV
    pcall(function()
        local mousePos = UserInputService:GetMouseLocation()
        local vpSize = Camera.ViewportSize
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                local tPart = player.Character:FindFirstChild(Settings.AimType == "Head" and "Head" or "HumanoidRootPart")
                local hum = player.Character:FindFirstChild("Humanoid")
                if tPart and hum and hum.Health > 0 then
                    local tPos, onScreen = Camera:WorldToViewportPoint(tPart.Position)
                    if onScreen and tPos.Z > 0 then
                        local dist = (Vector2.new(tPos.X, tPos.Y) - mousePos).Magnitude
                        if Settings.FOV360 then
                            if dist < closestDist then closestDist = dist closest = player end
                        else
                            local centerDist = (Vector2.new(tPos.X, tPos.Y) - Vector2.new(vpSize.X/2, vpSize.Y/2)).Magnitude
                            if centerDist <= Settings.FOV and dist < closestDist then closestDist = dist closest = player end
                        end
                    end
                end
            end
        end
    end)
    return closest
end

_G.getNearestPlayer = function()
    local nearest, shortDist = nil, math.huge
    pcall(function()
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                local hum = player.Character:FindFirstChild("Humanoid")
                if hum and hum.Health > 0 and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                    local dist = (LocalPlayer.Character.HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude
                    if dist < shortDist then shortDist = dist nearest = player end
                end
            end
        end
    end)
    return nearest
end

-- ESP SİSTEMİ
local ESPDrawings = {}
function createESP(player)
    if not DrawingSupported then return end
    pcall(function()
        if player == LocalPlayer then return end
        ESPDrawings[player] = { Box = Drawing.new("Square"), Name = Drawing.new("Text"), Health = Drawing.new("Text"), Distance = Drawing.new("Text") }
        local d = ESPDrawings[player]
        d.Box.Thickness, d.Box.Filled, d.Box.Color, d.Box.Transparency, d.Box.Visible = 1, false, Color3.new(1,1,1), 1, false
        d.Name.Size, d.Name.Outline, d.Name.Color, d.Name.Transparency, d.Name.Visible, d.Name.Center = 13, true, Color3.new(1,1,1), 1, false, true
        d.Health.Size, d.Health.Outline, d.Health.Color, d.Health.Transparency, d.Health.Visible, d.Health.Center = 11, true, Color3.fromRGB(100,255,100), 1, false, true
        d.Distance.Size, d.Distance.Outline, d.Distance.Color, d.Distance.Transparency, d.Distance.Visible, d.Distance.Center = 11, true, Color3.fromRGB(255,255,0), 1, false, true
    end)
end

function updateESP()
    if not DrawingSupported then return end
    pcall(function()
        for player, drawings in pairs(ESPDrawings) do
            local isVis = false
            if Settings.ESP and player and player.Character then
                local root = player.Character:FindFirstChild("HumanoidRootPart")
                local head = player.Character:FindFirstChild("Head")
                local hum = player.Character:FindFirstChild("Humanoid")
                
                if root and head and hum and hum.Health > 0 then
                    local rootPos, onScreen = Camera:WorldToViewportPoint(root.Position)
                    local dist = (Camera.CFrame.Position - root.Position).Magnitude
                    if onScreen and rootPos.Z > 0 and dist <= Settings.ESPDistanceLimit then
                        isVis = true
                        local headPos = Camera:WorldToViewportPoint(head.Position)
                        local h = math.abs(headPos.Y - rootPos.Y) * 2
                        local w = h * 0.6
                        local bx, by = rootPos.X - w/2, rootPos.Y - h/2
                        local hp = hum.Health / hum.MaxHealth
                        local clr = Color3.fromRGB(255 * (1 - hp), 255 * hp, 0)
                        
                        if Settings.ESPBox then drawings.Box.Visible, drawings.Box.Size, drawings.Box.Position, drawings.Box.Color = true, Vector2.new(w,h), Vector2.new(bx,by), clr else drawings.Box.Visible = false end
                        if Settings.ESPName then drawings.Name.Visible, drawings.Name.Text, drawings.Name.Position, drawings.Name.Color = true, player.Name, Vector2.new(rootPos.X, by - 18), clr else drawings.Name.Visible = false end
                        if Settings.ESPHealth then drawings.Health.Visible, drawings.Health.Text, drawings.Health.Position, drawings.Health.Color = true, math.floor(hum.Health).."/"..math.floor(hum.MaxHealth), Vector2.new(rootPos.X, by + h + 5), Color3.fromRGB(100, 255, 100) else drawings.Health.Visible = false end
                        if Settings.ESPDistance then drawings.Distance.Visible, drawings.Distance.Text, drawings.Distance.Position, drawings.Distance.Color = true, math.floor(dist).."m", Vector2.new(bx + w + 5, by), Color3.fromRGB(255, 255, 0) else drawings.Distance.Visible = false end
                    end
                end
            end
            if not isVis then drawings.Box.Visible, drawings.Name.Visible, drawings.Health.Visible, drawings.Distance.Visible = false, false, false, false end
        end
    end)
end

Players.PlayerAdded:Connect(createESP)
Players.PlayerRemoving:Connect(function(p) pcall(function() if ESPDrawings[p] then for _, d in pairs(ESPDrawings[p]) do d:Remove() end ESPDrawings[p] = nil end end) end)
