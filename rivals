-- CRASH KORUMALI AIMBOT DÖNGÜSÜ (MOBİL İÇİN HEARTBEAT OPTİMİZASYONU)
RunService.Heartbeat:Connect(function()
    pcall(function()
        local ct = tick()
        if ct - lastUpdate < updateInterval then return end
        lastUpdate = ct
        
        if Settings.Aimbot and FOVCircle then FOVCircle.Position, FOVCircle.Visible = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2), true else if FOVCircle then FOVCircle.Visible = false end end
        
        if Settings.Aimbot and aimbotActive and currentTarget and currentTarget.Character then
            local tp = currentTarget.Character:FindFirstChild(Settings.AimType == "Head" and "Head" or "HumanoidRootPart")
            if tp then
                if isMobile then
                    local dist = (Camera.CFrame.Position - tp.Position).Magnitude
                    if dist > 1 then
                        Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, tp.Position), Settings.Smooth)
                    end
                else
                    local hp = Camera:WorldToViewportPoint(tp.Position + Vector3.new(0, 0.2, 0))
                    if hp.Z > 0 then
                        local mp = UserInputService:GetMouseLocation()
                        if mousemoverel then mousemoverel((hp.X - mp.X) * Settings.Smooth, (hp.Y - mp.Y) * Settings.Smooth) end
                    end
                end
            end
        end
        updateESP()
    end)
end)

